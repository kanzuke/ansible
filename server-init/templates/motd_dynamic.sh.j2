#!/bin/bash
# MOTD Dynamique - Généré par Ansible
# Ne pas modifier manuellement

# Couleurs
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ───── Collecte des données système ─────

HOSTNAME=$(hostname -f 2>/dev/null || hostname)
OS=$(grep PRETTY_NAME /etc/os-release | cut -d'"' -f2)
KERNEL=$(uname -r)
ARCH=$(uname -m)
UPTIME=$(uptime -p | sed 's/up //')
LAST_BOOT=$(who -b | awk '{print $3, $4}')
USERS_LOGGED=$(who | wc -l)
LOAD=$(cat /proc/loadavg | awk '{print $1, $2, $3}')

# CPU
CPU_MODEL=$(grep "model name" /proc/cpuinfo | head -1 | cut -d':' -f2 | xargs)
CPU_CORES=$(nproc)
CPU_USAGE=$(top -bn1 | grep "Cpu(s)" | awk '{print 100 - $8}' | cut -d'.' -f1 2>/dev/null || \
            top -bn1 | grep "%Cpu" | awk '{print $2}' | cut -d'.' -f1)
# Barre de progression CPU
cpu_bar() {
    local percent=$1
    local bar_size=20
    local filled=$(( percent * bar_size / 100 ))
    local empty=$(( bar_size - filled ))
    local bar=""
    for ((i=0; i<filled; i++)); do bar="${bar}█"; done
    for ((i=0; i<empty; i++)); do bar="${bar}░"; done
    echo "$bar"
}

# RAM
RAM_TOTAL_KB=$(grep MemTotal /proc/meminfo | awk '{print $2}')
RAM_AVAIL_KB=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
RAM_USED_KB=$(( RAM_TOTAL_KB - RAM_AVAIL_KB ))
RAM_TOTAL=$(awk "BEGIN {printf \"%.1f\", $RAM_TOTAL_KB/1024/1024}")
RAM_USED=$(awk "BEGIN {printf \"%.1f\", $RAM_USED_KB/1024/1024}")
RAM_PERCENT=$(awk "BEGIN {printf \"%d\", ($RAM_USED_KB/$RAM_TOTAL_KB)*100}")
# Barre de progression RAM
ram_bar() {
    local percent=$1
    local bar_size=20
    local filled=$(( percent * bar_size / 100 ))
    local empty=$(( bar_size - filled ))
    local bar=""
    for ((i=0; i<filled; i++)); do bar="${bar}█"; done
    for ((i=0; i<empty; i++)); do bar="${bar}░"; done
    echo "$bar"
}

# Stockage (partition racine)
DISK_INFO=$(df -h / | tail -1)
DISK_TOTAL=$(echo "$DISK_INFO" | awk '{print $2}')
DISK_USED=$(echo "$DISK_INFO" | awk '{print $3}')
DISK_AVAIL=$(echo "$DISK_INFO" | awk '{print $4}')
DISK_PERCENT=$(echo "$DISK_INFO" | awk '{print $5}' | tr -d '%')
# Barre de progression Disque
disk_bar() {
    local percent=$1
    local bar_size=20
    local filled=$(( percent * bar_size / 100 ))
    local empty=$(( bar_size - filled ))
    local bar=""
    for ((i=0; i<filled; i++)); do bar="${bar}█"; done
    for ((i=0; i<empty; i++)); do bar="${bar}░"; done
    echo "$bar"
}

# Couleur selon le seuil d'utilisation
get_color() {
    local percent=$1
    if [ "$percent" -lt 60 ]; then
        echo -e "${GREEN}"
    elif [ "$percent" -lt 85 ]; then
        echo -e "${YELLOW}"
    else
        echo -e "${RED}"
    fi
}

# IP locale
IP_LOCAL=$(hostname -I | awk '{print $1}')

# IP publique (timeout rapide pour ne pas bloquer)
IP_PUBLIC=$(curl -s --connect-timeout 2 ifconfig.me 2>/dev/null || echo "N/A")

# Mises à jour disponibles
if command -v apt &>/dev/null; then
    UPDATES=$(apt list --upgradable 2>/dev/null | grep -c upgradable 2>/dev/null || echo "0")
    UPDATES=$(( UPDATES - 1 )) # Retirer l'en-tête
    [ "$UPDATES" -lt 0 ] && UPDATES=0
elif command -v dnf &>/dev/null; then
    UPDATES=$(dnf check-update --quiet 2>/dev/null | grep -c "^[a-zA-Z]" || echo "0")
fi

# Processus actifs
PROCESSES=$(ps aux | wc -l)

# ───── Affichage ─────

clear
echo ""
echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}${BOLD}║            INFORMATIONS SYSTÈME - $(date '+%d/%m/%Y %H:%M:%S')            ║${NC}"
echo -e "${CYAN}${BOLD}╠══════════════════════════════════════════════════════════════════╣${NC}"

echo -e "${CYAN}║${NC} ${WHITE}${BOLD}🖥  Système${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Hostname   :${NC} ${WHITE}${HOSTNAME}${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}OS         :${NC} ${WHITE}${OS}${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Kernel     :${NC} ${WHITE}${KERNEL} (${ARCH})${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Uptime     :${NC} ${WHITE}${UPTIME}${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Dernier boot :${NC} ${WHITE}${LAST_BOOT}${NC}"

echo -e "${CYAN}╠══════════════════════════════════════════════════════════════════╣${NC}"
echo -e "${CYAN}║${NC} ${WHITE}${BOLD}🌐  Réseau${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}IP Locale  :${NC} ${WHITE}${IP_LOCAL}${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}IP Publique:${NC} ${WHITE}${IP_PUBLIC}${NC}"

echo -e "${CYAN}╠══════════════════════════════════════════════════════════════════╣${NC}"
echo -e "${CYAN}║${NC} ${WHITE}${BOLD}⚙  CPU${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Modèle     :${NC} ${WHITE}${CPU_MODEL}${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Cœurs      :${NC} ${WHITE}${CPU_CORES}${NC}"
CPU_COLOR=$(get_color ${CPU_USAGE:-0})
CPU_BAR=$(cpu_bar ${CPU_USAGE:-0})
echo -e "${CYAN}║${NC}   ${BLUE}Utilisation:${NC} ${CPU_COLOR}${CPU_BAR}${NC} ${CPU_COLOR}${BOLD}${CPU_USAGE:-0}%${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Charge     :${NC} ${WHITE}${LOAD}${NC}"

echo -e "${CYAN}╠══════════════════════════════════════════════════════════════════╣${NC}"
echo -e "${CYAN}║${NC} ${WHITE}${BOLD}🧠  Mémoire RAM${NC}"
RAM_COLOR=$(get_color ${RAM_PERCENT})
RAM_BAR=$(ram_bar ${RAM_PERCENT})
echo -e "${CYAN}║${NC}   ${BLUE}Utilisée   :${NC} ${RAM_COLOR}${RAM_BAR}${NC} ${RAM_COLOR}${BOLD}${RAM_PERCENT}%${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Détail     :${NC} ${WHITE}${RAM_USED} Go / ${RAM_TOTAL} Go${NC}"

echo -e "${CYAN}╠══════════════════════════════════════════════════════════════════╣${NC}"
echo -e "${CYAN}║${NC} ${WHITE}${BOLD}💾  Stockage (/)${NC}"
DISK_COLOR=$(get_color ${DISK_PERCENT})
DISK_BAR=$(disk_bar ${DISK_PERCENT})
echo -e "${CYAN}║${NC}   ${BLUE}Utilisé    :${NC} ${DISK_COLOR}${DISK_BAR}${NC} ${DISK_COLOR}${BOLD}${DISK_PERCENT}%${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Détail     :${NC} ${WHITE}${DISK_USED} utilisés / ${DISK_TOTAL} total (${DISK_AVAIL} libres)${NC}"

echo -e "${CYAN}╠══════════════════════════════════════════════════════════════════╣${NC}"
echo -e "${CYAN}║${NC} ${WHITE}${BOLD}📊  Activité${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Processus  :${NC} ${WHITE}${PROCESSES}${NC}"
echo -e "${CYAN}║${NC}   ${BLUE}Sessions   :${NC} ${WHITE}${USERS_LOGGED} utilisateur(s) connecté(s)${NC}"

if [ "${UPDATES}" -gt 0 ]; then
    echo -e "${CYAN}╠══════════════════════════════════════════════════════════════════╣${NC}"
    echo -e "${CYAN}║${NC} ${YELLOW}${BOLD}🔔  ${UPDATES} mise(s) à jour disponible(s)${NC}"
fi

echo -e "${CYAN}╚══════════════════════════════════════════════════════════════════╝${NC}"
echo ""
